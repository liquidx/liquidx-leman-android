<?xml version="1.0" encoding="utf-8"?>
<!-- See backup_rules.xml — the encrypted API key is excluded from both cloud
     backup and device-to-device transfer (spec 03). -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/apikey.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/apikey.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
