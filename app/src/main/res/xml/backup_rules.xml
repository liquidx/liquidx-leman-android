<?xml version="1.0" encoding="utf-8"?>
<!-- The encrypted API key never leaves the device: "key stored in secure
     enclave · never synced" (spec 03). Thread data is ordinary app storage;
     the user exports it explicitly from 2d. -->
<full-backup-content>
    <exclude domain="file" path="datastore/apikey.preferences_pb" />
</full-backup-content>
